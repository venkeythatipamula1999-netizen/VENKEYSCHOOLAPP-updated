rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the user themselves or admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && (request.auth.uid == resource.data.uid 
            || request.auth.token.role == 'principal');
    }

    // Students — any authenticated user can read,
    // only principal/admin can write
    match /students/{studentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Classes
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Student marks — authenticated read, 
    // authenticated write (teacher permission 
    // enforced at API level)
    match /student_marks/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Attendance
    match /student_attendance/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /attendance_records/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /attendance_submissions/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /attendance_edits/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Parent accounts — only the parent themselves
    match /parent_accounts/{docId} {
      allow read: if request.auth != null 
        && request.auth.uid == resource.data.uid;
      allow write: if request.auth != null 
        && request.auth.uid == resource.data.uid;
    }

    // Parent notifications — parent can read their own
    match /parent_notifications/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Fee records — authenticated read only,
    // no direct client writes
    match /fee_records/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /fee_reminders/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bus & transport
    match /buses/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /bus_trips/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /trip_scans/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /live_bus_locations/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /student_stops/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Leave requests
    match /leave_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /leaveRequests/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Notifications
    match /teacher_notifications/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /admin_notifications/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /driver_notifications/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Salary & payroll — sensitive, 
    // only authenticated access
    match /salary_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /salary_payments/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Staff duty
    match /staff_duty/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Events & calendar
    match /events/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /calendarEvents/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Student files / digital folder
    match /student_files/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Settings & school info
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Sync errors — server only, no client access
    match /sync_errors/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Scan rejection logs — server only
    match /scan_rejection_logs/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Promotion history — read only for authenticated
    match /promotionHistory/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Schools (super admin) — no client access
    match /schools/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
